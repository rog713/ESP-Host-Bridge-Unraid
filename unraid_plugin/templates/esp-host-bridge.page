<script>
(function () {
  var serviceEndpoint = '/plugins/esp-host-bridge/php/service.php';
  var csrfToken = <?=json_encode($csrfToken)?>;

  function escapeHtml(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function setText(id, value) {
    var el = document.getElementById(id);
    if (el) el.textContent = value;
  }

  function setHtml(id, value) {
    var el = document.getElementById(id);
    if (el) el.innerHTML = value;
  }

  function setVisible(id, visible) {
    var el = document.getElementById(id);
    if (el) el.style.display = visible ? '' : 'none';
  }

  function badge(text, kind) {
    return '<span class="hm-badge ' + kind + '">' + escapeHtml(text) + '</span>';
  }

  function pillClass(kind) {
    if (kind === 'ok' || kind === 'warn' || kind === 'danger') return 'hm-pill ' + kind;
    return 'hm-pill neutral';
  }

  function setPill(id, text, kind) {
    var el = document.getElementById(id);
    if (!el) return;
    el.className = pillClass(kind);
    el.textContent = text;
  }

  function flash(message, kind) {
    if (!message) {
      setHtml('hmFlash', '');
      return;
    }
    setHtml('hmFlash', badge(message, kind || 'neutral'));
  }

  function bridgeUrl(port) {
    return 'http://' + window.location.hostname + ':' + String(port || 8654) + '/';
  }

  function requestJson(data, method) {
    if (!window.jQuery || !window.jQuery.ajax) {
      return Promise.reject(new Error('jQuery is not available in this Unraid page context'));
    }
    return window.jQuery.ajax({
      url: serviceEndpoint,
      type: method || 'POST',
      data: data,
      dataType: 'json'
    }).then(function (response) {
      if (!response || response.ok === false) {
        throw new Error((response && response.message) || 'Request failed');
      }
      return response;
    }, function (xhr) {
      var payload = xhr && xhr.responseJSON ? xhr.responseJSON : null;
      var message = (payload && payload.message) || (xhr && xhr.statusText) || 'Request failed';
      throw new Error(message);
    });
  }

  function postAction(action, extra) {
    var data = window.jQuery.extend({}, extra || {}, { action: action, csrf_token: csrfToken });
    return requestJson(data, 'POST');
  }

  function formatTs(ts) {
    if (!ts) return '--';
    var d = new Date(Number(ts) * 1000);
    if (Number.isNaN(d.getTime())) return '--';
    return d.toLocaleString();
  }

  function ageText(seconds) {
    if (seconds == null || !isFinite(Number(seconds))) return '--';
    var s = Math.max(0, Math.round(Number(seconds)));
    if (s < 60) return s + 's';
    if (s < 3600) return Math.floor(s / 60) + 'm';
    if (s < 86400) return Math.floor(s / 3600) + 'h';
    return Math.floor(s / 86400) + 'd';
  }

  function humanBytes(value) {
    var n = Number(value);
    if (!isFinite(n) || n <= 0) return '--';
    var units = ['B', 'KB', 'MB', 'GB', 'TB', 'PB'];
    var idx = 0;
    while (n >= 1024 && idx < units.length - 1) {
      n /= 1024;
      idx += 1;
    }
    return n.toFixed(idx === 0 ? 0 : 1) + ' ' + units[idx];
  }

  function updateStatus(data) {
    var service = data.service || {};
    var plugin = data.plugin || {};
    var bridge = data.bridge || null;
    var comm = bridge && bridge.comm_status ? bridge.comm_status : {};
    var esp = bridge && bridge.esp_status ? bridge.esp_status : {};
    var unraid = bridge && bridge.unraid_status ? bridge.unraid_status : {};
    var arrayInfo = unraid && typeof unraid.array === 'object' ? unraid.array : {};
    var arrayCapacity = arrayInfo && typeof arrayInfo.capacity === 'object' ? arrayInfo.capacity : {};
    var diskCap = arrayCapacity && typeof arrayCapacity.disks === 'object' ? arrayCapacity.disks : {};
    var bridgeRunning = !!(bridge && bridge.running);
    var bridgeReachable = !!bridge;
    var telemetryAge = bridge && bridge.last_metrics_age_s != null ? Number(bridge.last_metrics_age_s) : null;
    var wifiConnected = String(esp.wifi_state || '').toLowerCase() === 'connected';
    var telemetryKind = telemetryAge == null ? 'warn' : (telemetryAge <= 5 ? 'ok' : 'warn');
    var serialKind = comm.serial_connected ? 'ok' : 'warn';
    var displayKind = esp.display_sleeping ? 'warn' : 'ok';
    var wifiKind = !esp.wifi_state ? 'warn' : (wifiConnected ? 'ok' : 'warn');
    var unraidKind = unraid.api_ok === true ? 'ok' : (unraid.api_ok === false ? 'warn' : 'neutral');
    var arrayState = arrayInfo && arrayInfo.state ? String(arrayInfo.state) : '--';
    var arrayUsage = '--';
    if (diskCap && diskCap.total != null && diskCap.used != null) {
      arrayUsage = humanBytes(diskCap.used) + ' / ' + humanBytes(diskCap.total);
    }

    setHtml('hmPluginState', badge(plugin.enabled ? 'Enabled' : 'Disabled', plugin.enabled ? 'ok' : 'warn'));
    setHtml('hmServiceState', badge(service.running ? 'Running' : 'Stopped', service.running ? 'ok' : 'warn'));
    setHtml('hmBridgeState', badge(bridgeReachable ? 'Reachable' : 'Unavailable', bridgeReachable ? 'ok' : 'warn'));
    setText('hmBridgeVersion', bridge && bridge.bridge_version ? bridge.bridge_version : '--');
    setText('hmPid', bridgeRunning && bridge.pid ? String(bridge.pid) : '--');
    setText('hmStarted', bridgeRunning ? formatTs(bridge.started_at) : '--');
    setText('hmPluginVersion', plugin.version || '--');
    setText('hmConfigPath', data.paths ? data.paths.plugin_cfg : '--');
    setText('hmBridgeConfigPath', data.paths ? data.paths.webui_cfg : '--');
    setText('hmLogPath', data.paths ? data.paths.log_file : '--');
    setText('hmServiceMessage', service.message || 'Use Open Web UI for detailed bridge configuration.');

    setPill('hmTelemetryHealth', 'Telemetry: ' + (telemetryAge == null ? 'Waiting' : 'Live (' + ageText(telemetryAge) + ')'), telemetryKind);
    setPill('hmSerialHealth', 'Serial: ' + (comm.serial_connected ? 'Connected' : 'Disconnected'), serialKind);
    setPill('hmHostStatus', 'Host: ' + (bridge && bridge.host_name ? bridge.host_name : '--'), bridge && bridge.host_name ? 'ok' : 'neutral');
    setPill('hmIfaceStatus', 'Active Interface: ' + (bridge && bridge.active_iface ? bridge.active_iface : '--'), bridge && bridge.active_iface ? 'ok' : 'neutral');
    setPill('hmDisplayStatus', 'Display: ' + (esp.display_sleeping ? 'Sleeping' : (bridgeReachable ? 'Awake' : '--')), displayKind);
    setPill('hmEspBoots', 'ESP Boots: ' + (esp.boot_count != null ? String(esp.boot_count) : '--'), esp.boot_count ? 'ok' : 'neutral');
    setPill('hmEspReset', 'Last ESP Reset: ' + (esp.last_boot_reason || '--'), esp.last_boot_reason ? 'ok' : 'neutral');
    setPill('hmEspWifi', 'ESP Wi-Fi: ' + (esp.wifi_state || '--'), wifiKind);
    setPill('hmEspWifiDetail', 'ESP Wi-Fi Detail: ' + ([esp.wifi_ssid || null, esp.wifi_ip || null, esp.wifi_rssi_dbm != null ? String(esp.wifi_rssi_dbm) + ' dBm' : null].filter(Boolean).join(' • ') || '--'), wifiKind);
    setPill('hmReconnects', 'Reconnects: ' + (comm.serial_disconnect_count != null ? String(comm.serial_disconnect_count) : '--'), (comm.serial_disconnect_count || 0) > 0 ? 'warn' : 'ok');
    setPill('hmLastComm', 'Comm: ' + (comm.last_comm_event_age_s != null ? ageText(comm.last_comm_event_age_s) + ' ago' : '--'), comm.last_comm_event_age_s != null ? 'ok' : 'neutral');
    setPill('hmUnraidApi', 'Unraid API: ' + (unraid.api_ok === true ? 'Connected' : (unraid.api_ok === false ? 'Unavailable' : 'Disabled')), unraidKind);
    setPill('hmArrayState', 'Array: ' + arrayState, arrayState !== '--' ? 'ok' : 'neutral');
    setPill('hmArrayCapacity', 'Array Usage: ' + arrayUsage, arrayUsage !== '--' ? 'ok' : 'neutral');
    setPill('hmDockerSource', 'Docker Source: ' + (unraid.api_ok === true ? 'Unraid API' : 'Docker Socket'), unraid.api_ok === true ? 'ok' : 'neutral');

    setVisible('hmStartBtn', !service.running);
    setVisible('hmStopBtn', service.running);
    setVisible('hmRestartBtn', service.running);
    document.getElementById('hmStartBtn').disabled = !!service.running || !plugin.enabled;
    document.getElementById('hmPort').value = plugin.HM_PORT || '8654';
    document.getElementById('hmBindHost').value = plugin.HM_BIND_HOST || '0.0.0.0';
    document.getElementById('hmAutostart').checked = String(plugin.HM_AUTOSTART || 'yes').toLowerCase() === 'yes';
    updateLink(data.webui_url || bridgeUrl(plugin.HM_PORT || '8654'));
  }

  function updateLink(url) {
    var openLink = document.getElementById('hmOpenUi');
    if (openLink) openLink.href = url;
  }

  function refreshStatus() {
    return requestJson({ action: 'status' }, 'GET')
      .then(function (data) {
        updateStatus(data);
      })
      .catch(function (err) {
        flash(err.message || err, 'danger');
      });
  }

  function refreshLog() {
    return requestJson({ action: 'tail_log', lines: 160 }, 'GET')
      .then(function (data) {
        setText('hmLogBox', data.log || 'Log file is empty.');
      })
      .catch(function (err) {
        setText('hmLogBox', 'Failed to load log: ' + (err.message || err));
      });
  }

  function bindAction(id, action) {
    var el = document.getElementById(id);
    if (!el) return;
    el.addEventListener('click', function () {
      postAction(action).then(function (data) {
        flash(data.message || (action + ' completed'), 'ok');
        return Promise.all([refreshStatus(), refreshLog()]);
      }).catch(function (err) {
        flash(err.message || err, 'danger');
      });
    });
  }

  bindAction('hmStartBtn', 'start');
  bindAction('hmStopBtn', 'stop');
  bindAction('hmRestartBtn', 'restart');
  bindAction('hmEnableBtn', 'enable');
  bindAction('hmDisableBtn', 'disable');

  var refreshBtn = document.getElementById('hmRefreshBtn');
  if (refreshBtn) {
    refreshBtn.addEventListener('click', function () {
      Promise.all([refreshStatus(), refreshLog()]);
    });
  }

  var logRefreshBtn = document.getElementById('hmLogRefreshBtn');
  if (logRefreshBtn) {
    logRefreshBtn.addEventListener('click', function () {
      refreshLog();
    });
  }

  var form = document.getElementById('hmSettingsForm');
  if (form) {
    form.addEventListener('submit', function (event) {
      event.preventDefault();
      postAction('save', {
        port: String(document.getElementById('hmPort').value || ''),
        bind_host: String(document.getElementById('hmBindHost').value || ''),
        autostart: document.getElementById('hmAutostart').checked ? 'yes' : ''
      }).then(function (data) {
        flash(data.message || 'Saved plugin settings', 'ok');
        return refreshStatus();
      }).catch(function (err) {
        flash(err.message || err, 'danger');
      });
    });
  }

  if (!window.jQuery || !window.jQuery.ajax) {
    flash('Unraid page dependencies did not load. jQuery is required for this page.', 'danger');
    return;
  }

  Promise.all([refreshStatus(), refreshLog()]);
  window.setInterval(refreshStatus, 5000);
  window.setInterval(refreshLog, 8000);
})();
</script>
